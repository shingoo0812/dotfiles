{
  "autoUpdatesChannel": "latest",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy RemoteSigned -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code', 'Claudeが入力を待っています' -Sound Default\"",
            "timeout": 8
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy RemoteSigned -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code', 'タスクが完了しました' -Sound Default\"",
            "timeout": 8
          }
        ]
      }
    ]
  },
  "theme": "dark-daltonized",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "mcpServers": {
    "neovim": {
      "command": "node",
      "args": [
        "C:/Users/shing/AppData/Roaming/npm/node_modules/mcp-neovim-server/build/index.js"
      ],
      "env": {
        "NVIM_SOCKET_PATH": "\\\\.\\pipe\\nvim"
      }
    }
  }
}
