{
  "autoUpdatesChannel": "latest",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy RemoteSigned -File \"C:\\Users\\shingo\\.claude\\hooks\\ollama-triage-prompt.ps1\"",
            "timeout": 35
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -File \"C:\\Users\\shingo\\.claude\\hooks\\update-package-lists.ps1\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -File \"C:\\Users\\shingo\\.claude\\hooks\\cleanup-temp-files.ps1\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__ollama__",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -File \"C:\\Users\\shingo\\.claude\\hooks\\ollama-usage-log.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy RemoteSigned -File \"C:\\Users\\shingo\\.claude\\hooks\\notify.ps1\"",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy RemoteSigned -File \"C:\\Users\\shingo\\.claude\\hooks\\notify.ps1\" -Message 'タスクが完了しました'",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\shingo\\.claude\\hooks\\stop-git-check.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"C:\\Users\\shingo\\.claude\\hooks\\session-start-check.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "theme": "dark-daltonized",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "permissions": {
    "allow": [
      "mcp__rag__rag_query",
      "mcp__rag__rag_stats",
      "mcp__comfyui__comfyui_stats",
      "mcp__comfyui__comfyui_queue",
      "mcp__comfyui__comfyui_search_nodes",
      "mcp__comfyui__comfyui_node_info",
      "mcp__comfyui__comfyui_list_workflows",
      "mcp__comfyui__comfyui_load_workflow",
      "mcp__comfyui__comfyui_save_workflow",
      "mcp__comfyui__comfyui_submit_workflow",
      "mcp__comfyui__comfyui_get_history",
      "mcp__comfyui__comfyui_get_outputs",
      "mcp__comfyui__comfyui_get_log",
      "mcp__comfyui__comfyui_get_errors",
      "mcp__comfyui__comfyui_interrupt",
      "mcp__comfyui__comfyui_free_memory",
      "PowerShell(Get-Content *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Select-String *)",
      "PowerShell(Get-Item *)",
      "PowerShell(Get-Process *)",
      "PowerShell(Get-Member *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Measure-Object *)",
      "PowerShell(Invoke-WebRequest \"http://localhost:8188*)"
    ]
  },
  "mcpServers": {
    "blender": {
      "command": "C:/Users/shingo/miniconda3/python.exe",
      "args": [
        "-u",
        "C:/Users/shingo/AppData/Local/dotfiles/blender-mcp/blender_mcp_bridge.py"
      ]
    },
    "neovim": {
      "command": "node",
      "args": [
        "C:/Users/shing/AppData/Roaming/npm/node_modules/mcp-neovim-server/build/index.js"
      ],
      "env": {
        "NVIM_SOCKET_PATH": "\\\\.\\pipe\\nvim"
      }
    },
    "ollama": {
      "command": "C:/Users/shingo/miniconda3/python.exe",
      "args": [
        "C:/Users/shingo/AppData/Local/dotfiles/ollama-mcp/ollama_server.py"
      ]
    },
    "comfyui": {
      "command": "C:/Users/shingo/miniconda3/python.exe",
      "args": [
        "-u",
        "C:/Users/shingo/AppData/Local/dotfiles/mcp/comfyui/comfyui_mcp_server.py"
      ]
    }
  }
}